# =============================================================================
# hermes-neo TestAgent Environment
# Copy to .env and fill in your values
# =============================================================================

# ---- Tailscale ----
TS_AUTHKEY=tskey-auth-XXXXXXXXXX
TS_HOSTNAME=hermes-neo-agent

# ---- Hermes Agent ----
HERMES_PROVIDER=xiaomi
HERMES_API_KEY=your-api-key-here
HERMES_MODEL=mimo-v2.5-pro
HERMES_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# ---- Telegram Gateway (optional) ----
TELEGRAM_BOT_TOKEN=

# ---- OpenRouter (optional, for fallback) ----
OPENROUTER_API_KEY=

# ---- Firecrawl (self-hosted) ----
FIRECRAWL_API_URL=http://firecrawl:3002

# ---- SearXNG (self-hosted search) ----
SEARXNG_URL=http://searxng:8080
